{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://YOUR_BACKEND_URL/api/$1"
    },
    {
      "src": "/ws",
      "dest": "https://YOUR_BACKEND_URL/ws"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "https://YOUR_BACKEND_URL",
    "VITE_WS_URL": "wss://YOUR_BACKEND_URL"
  }
}
